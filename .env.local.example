# AI-BOCK Pocket — Environment Variables
# Kopiere diese Datei zu .env.local und trage die Werte ein

# Passwort für Login
POCKET_PASSWORD=dein-sicheres-passwort

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# GitHub PAT (Fine-grained: Contents read+write auf ai-bock-cloud)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=Ai-Bock-AT/ai-bock-cloud
GITHUB_BRANCH=main

# Session Cookie Secret (32+ zufällige Zeichen)
# Generieren: openssl rand -hex 32
SESSION_SECRET=...
